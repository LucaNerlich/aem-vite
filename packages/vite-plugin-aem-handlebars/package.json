{
  "name": "@aemvite/vite-plugin-aem-handlebars",
  "version": "0.6.0",
  "description": "Vite plugin that precompiles `.template.hbs` files into Handlebars runtime functions and stubs Storybook/non-template `.hbs` partials, mirroring webpack handlebars-loader + IgnorePlugin for AEM clientlib builds.",
  "keywords": [
    "aem",
    "clientlib",
    "vite",
    "vite-plugin",
    "handlebars",
    "handlebars-loader",
    "precompile",
    "templates",
    "storybook",
    "aemvite"
  ],
  "homepage": "https://github.com/LucaNerlich/aem-vite#readme",
  "bugs": {
    "url": "https://github.com/LucaNerlich/aem-vite/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LucaNerlich/aem-vite.git",
    "directory": "packages/vite-plugin-aem-handlebars"
  },
  "license": "MIT",
  "author": "Luca Nerlich",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": "^22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "handlebars": "^4.7",
    "vite": "^8"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "handlebars": "^4.7.8",
    "typescript": "^5.9.3",
    "vite": "8.1.0",
    "vitest": "4.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
