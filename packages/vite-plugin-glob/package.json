{
  "name": "@aemvite/vite-plugin-glob",
  "version": "0.5.1",
  "description": "Vite plugin that expands glob specifiers inside .scss and .css files (replacement for glob-import-loader).",
  "keywords": [
    "aem",
    "vite",
    "vite-plugin",
    "glob",
    "scss",
    "css",
    "clientlib",
    "edge-delivery",
    "aemvite"
  ],
  "homepage": "https://github.com/LucaNerlich/aem-vite#readme",
  "bugs": {
    "url": "https://github.com/LucaNerlich/aem-vite/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LucaNerlich/aem-vite.git",
    "directory": "packages/vite-plugin-glob"
  },
  "license": "MIT",
  "author": "Luca Nerlich",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./expand": {
      "types": "./dist/expand.d.ts",
      "default": "./dist/expand.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": "^22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "tinyglobby": "^0.2.17"
  },
  "peerDependencies": {
    "vite": "^8"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "typescript": "^5.9.3",
    "vite": "8.1.0",
    "vitest": "4.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
