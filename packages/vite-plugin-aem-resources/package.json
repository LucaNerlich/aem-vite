{
  "name": "@aemvite/vite-plugin-aem-resources",
  "version": "0.7.0",
  "description": "Vite plugin that copies an AEM clientlib resources/ tree into the build output, skipping .gitkeep-only / empty sources.",
  "keywords": [
    "aem",
    "clientlib",
    "vite",
    "vite-plugin",
    "resources",
    "copy",
    "edge-delivery",
    "aemvite"
  ],
  "homepage": "https://github.com/LucaNerlich/aem-vite#readme",
  "bugs": {
    "url": "https://github.com/LucaNerlich/aem-vite/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LucaNerlich/aem-vite.git",
    "directory": "packages/vite-plugin-aem-resources"
  },
  "license": "MIT",
  "author": "Luca Nerlich",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": "^20.19.0 || ^22.18.0 || >=24.11.0"
  },
  "scripts": {
    "build": "vp pack src/index.ts --dts",
    "test": "vp test run",
    "test:watch": "vp test",
    "lint": "vp lint",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "vite": "^8"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.0",
    "vite-plus": "^0.2.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
