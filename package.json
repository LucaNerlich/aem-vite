{
  "name": "aemvite-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @aemvite/vite-plugin-aem-clientlib && npm run build -w @aemvite/vite-plugin-glob && npm run build -w @aemvite/vite-plugin-aem-resources && npm run build -w @aemvite/aem-config",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "vite": "^8.1.0"
  },
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800"
}
